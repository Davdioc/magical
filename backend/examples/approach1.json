      "instructionsDoc": {
        "commands": [
          {
            "id": "da69f557-14ae-40d8-aa88-479478dac11d",
            "orderKey": 0,
            "state": "active",
            "commandId": "custom",
            "input": {
              "instructions": "Extract all Auth IDs from the Web page and return them as an ordered list.\nSorting rules (apply in order):\n1. Priority: `high` before `standard`\n2. Within the same priority: earlier `date_submitted` first (ascending)\nOutput format:\nReturn only an array of strings, with no commentary, code fences, or extra keys.\nExample: [\"PA-2024-001\", \"PA-2025-001\"]\nEdge cases:\n- If `priority` is missing, treat it as `standard`\n- If `date_submitted` is missing or unparseable, place the record last within its priority group\n- If no Auth IDs are found, return `[]`\n- Preserve the exact formatting of Auth IDs as they appear in the source"
            }
          }
        ],
        "comments": []
      },
      "config": {
        "tools": [
          "callSpecializedAgent",
          "copy"
        ],
        "environmentOptions": {
          "environment": "browser",
          "saveAuthCookiesAfterRun": false,
          "startingUrl": "https://v0-ehr-queue-with-downloads.vercel.app/",
          "browserProvider": "browserbase"
